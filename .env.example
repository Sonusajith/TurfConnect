# =========================================================================
# TurfConnect Environment Variables (Template)
# Copy this file to '.env' and fill in your local/staging credentials.
# NEVER commit the actual '.env' file containing real secrets to Git.
# =========================================================================

# --- MongoDB Connections (Database-per-service) ---
AUTH_MONGO_URI=mongodb://localhost:27017/turfconnect_auth
TURF_MONGO_URI=mongodb://localhost:27017/turfconnect_turf
BOOKING_MONGO_URI=mongodb://localhost:27017/turfconnect_booking
PAYMENT_MONGO_URI=mongodb://localhost:27017/turfconnect_payment
NOTIFICATION_MONGO_URI=mongodb://localhost:27017/turfconnect_notification
REVIEW_MONGO_URI=mongodb://localhost:27017/turfconnect_review
COMMUNITY_MONGO_URI=mongodb://localhost:27017/turfconnect_community
TOURNAMENT_MONGO_URI=mongodb://localhost:27017/turfconnect_tournament
RECOMMEND_MONGO_URI=mongodb://localhost:27017/turfconnect_recommend
ANALYTICS_MONGO_URI=mongodb://localhost:27017/turfconnect_analytics
ORG_MONGO_URI=mongodb://localhost:27017/turfconnect_org

# --- Redis Distributed Cache & Locking ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# --- Messaging Broker (RabbitMQ) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- JWT Authentication (Security) ---
JWT_SECRET=your_super_secret_signing_key_at_least_256_bits_long_here
JWT_EXPIRATION_MS=900000          # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000 # 7 days

# --- Third-Party Integrations ---
# Razorpay Credentials (Test Mode Only)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Frontend payment mode. Use RAZORPAY for the real checkout screen, MOCK for old offline-only demo.
VITE_PAYMENT_PROVIDER=RAZORPAY
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Stripe Credentials (Test Mode Only - Alternative)
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# SMTP Email Settings (Notification Service)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM_EMAIL=no-reply@turfconnect.com
